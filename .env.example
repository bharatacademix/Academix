# Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values

# App Configuration
VITE_APP_NAME=Global Academic Assist

# Supabase Configuration
# Get these from: https://app.supabase.com/projects
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API (for Workers deployment)
# VITE_API_URL=https://api.your-domain.com

# Google AdSense Configuration
# Get your Publisher ID from: https://adsense.google.com
VITE_GOOGLE_ADSENSE_PUBLISHER_ID=ca-pub-9096209867795576

# Ad Unit IDs (create these in your AdSense dashboard)
# Format: 123456789 (without ad prefix)
VITE_ADSENSE_AD_UNIT_TOP=
VITE_ADSENSE_AD_UNIT_SIDEBAR=
VITE_ADSENSE_AD_UNIT_ARTICLE=
VITE_ADSENSE_AD_UNIT_BOTTOM=
